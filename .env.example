# Local development placeholders only. Do not put real secrets here.
# Launch modes: historical_replay, sandbox, shadow, production.
# Production requires a separate explicit confirmation; keep it unset by default.
TRADING_RUNTIME_MODE=historical_replay
# SQLite fallback is allowed only for explicit one-process local experiments.
# TRADING_RUNTIME_LOCAL_SQLITE=1
# TRADING_PRODUCTION_CONFIRM=I_UNDERSTAND_LIVE_ORDERS
LOG_LEVEL=INFO

# Compose secrets are mounted under /run/secrets/*.
TBANK_FULL_ACCESS_TOKEN_FILE=/run/secrets/tbank_full_access_token
TBANK_READONLY_TOKEN_FILE=/run/secrets/tbank_readonly_token
TBANK_ENVIRONMENT=sandbox
TBANK_APP_NAME=Resurt.Trading_2_0
TBANK_MAX_RETRY_ATTEMPTS=3
SSL_TBANK_VERIFY=true
TBANK_UNARY_TIMEOUT_FLOOR_SECONDS=5.0
# Historical candle backfill uses readonly calls only. Use shadow for live readonly history.
TRADING_BACKFILL_RUNTIME_MODE=shadow

# Non-secret local compose settings.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_2_0
POSTGRES_USER=trading_app
POSTGRES_PASSWORD_FILE=secrets/postgres_password
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_DEFAULT_QUEUE=reports
CELERY_REPORTS_QUEUE=reports
TRADING_AUTH_MODE=dev
# Production-like API auth:
# TRADING_AUTH_MODE=static_bearer
# TRADING_API_OPERATOR_TOKEN_FILE=secrets/api_operator_token
# TRADING_WS_TICKET_SECRET_FILE=secrets/ws_ticket_secret
REDIS_PORT=6379
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRADE_CORE_PORT=8001
REPORT_WORKER_PORT=8002
FRONTEND_PORT=5173
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
FLUENT_BIT_HTTP_PORT=2020
FLUENT_BIT_FORWARD_PORT=24224
GRAFANA_ADMIN_USER=admin

# Frontend build/runtime placeholders. Do not commit real bearer tokens.
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_TRADING_RUNTIME_MODE=historical_replay
VITE_API_AUTH_MODE=dev
# VITE_API_AUTH_MODE=static_bearer
# VITE_API_BEARER_TOKEN=
