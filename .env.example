# Local development placeholders only. Do not put real tokens here.
TRADING_RUNTIME_MODE=historical_replay
LOG_LEVEL=INFO

# Production uses Docker Compose secrets under /run/secrets/*.
TBANK_FULL_ACCESS_TOKEN_FILE=/run/secrets/tbank_full_access_token
TBANK_READONLY_TOKEN_FILE=/run/secrets/tbank_readonly_token

# Local placeholders; step 02 will introduce real compose wiring.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_2_0
POSTGRES_USER=trading_app
POSTGRES_PASSWORD=local_placeholder_not_secret
REDIS_URL=redis://localhost:6379/0
