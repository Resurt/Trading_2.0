{
  "name": "trading-2-0-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "analytics-smoke": "cd ../.. && python scripts/run_logging_analytics_acceptance.py",
    "report-rebuild": "cd ../.. && python scripts/run_report_rebuild.py",
    "replay-day": "cd ../.. && python scripts/run_replay_day.py",
    "observability-up": "cd ../.. && docker compose up -d prometheus grafana loki fluent-bit"
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "pinia": "^3.0.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  }
}
